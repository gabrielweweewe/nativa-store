SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Nova chave (Settings → API Keys → Secret keys)
SUPABASE_SECRET_KEY=sb_secret_sua_chave_completa_aqui

# Frontend — login de clientes (Settings → API Keys → Publishable / anon)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# URL pública do site (produção) — usada nos links de e-mail do Supabase Auth
# Ex.: https://sua-loja.vercel.app  (sem barra no final)
VITE_APP_URL=https://sua-loja.vercel.app

# Ou chave legacy (Settings → API Keys → aba Legacy → service_role)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

API_PORT=3001

# Migração Nuvemshop (opcional — para buscar imagens dos produtos)
NUVEMSHOP_STORE_URL=https://www.nativa.art.br
# TIENDANUBE_CSV_PATH=tiendanube-6418246-17834446675007348008384088291.csv

# Painel administrativo (/admin)
ADMIN_PASSWORD=defina_uma_senha_forte_aqui
ADMIN_JWT_SECRET=defina_um_segredo_aleatorio_longo_aqui
