SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Nova chave (Settings → API Keys → Secret keys)
SUPABASE_SECRET_KEY=sb_secret_sua_chave_completa_aqui

# Frontend — login de clientes (Settings → API Keys → Publishable / anon)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# URL pública do site (produção) — usada nos links de e-mail do Supabase Auth
# Ex.: https://sua-loja.vercel.app  (sem barra no final)
VITE_APP_URL=https://sua-loja.vercel.app

# WhatsApp da loja (DDI + DDD + número, só dígitos). Usado no botão flutuante e na PDP.
# VITE_WHATSAPP_NUMBER=5511976984558

# Ou chave legacy (Settings → API Keys → aba Legacy → service_role)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

API_PORT=3001

# Migração Nuvemshop (opcional — para buscar imagens dos produtos)
NUVEMSHOP_STORE_URL=https://www.nativa.art.br
# TIENDANUBE_CSV_PATH=tiendanube-6418246-17834446675007348008384088291.csv

# Painel administrativo (/admin)
ADMIN_PASSWORD=defina_uma_senha_forte_aqui
ADMIN_JWT_SECRET=defina_um_segredo_aleatorio_longo_aqui

# URL pública do site (também usada no callback OAuth Melhor Envio e nas meta tags OG)
# APP_URL=https://sua-loja.vercel.app

# Melhor Envio: Client ID/Secret e tokens ficam no admin (/admin/integracoes)
# e na tabela melhor_envio_settings (execute supabase/melhor_envio.sql)

# Mercado Pago: credenciais ficam criptografadas na tabela mercado_pago_settings.
# Gere um segredo aleatório longo e configure o mesmo valor no Vercel.
MERCADO_PAGO_ENCRYPTION_KEY=gere_um_segredo_aleatorio_com_ao_menos_32_caracteres

# Brevo: a API Key e o token do webhook ficam criptografados no Supabase.
# Configure esta chave somente no backend/Vercel; nunca use prefixo VITE_.
BREVO_ENCRYPTION_KEY=gere_outro_segredo_aleatorio_com_ao_menos_32_caracteres
# Opcional: substitui o token salvo pelo admin para autenticar o webhook.
# BREVO_WEBHOOK_TOKEN=token_aleatorio_com_ao_menos_32_caracteres
